# LLM provider selection: claude | openai | offline
# Missing keys automatically fall back to "offline" (rule-based reports, no external calls).
LLM_PROVIDER=offline

# Anthropic Claude
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-opus-4-8

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Data
DEFAULT_DATA_SOURCE=yfinance
MARKET_INDEX_SYMBOL=^TWII

# Storage
DB_PATH=backtesting_copilot.sqlite
