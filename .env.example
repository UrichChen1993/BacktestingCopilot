# LLM provider selection: claude | openai | gemini | ollama | offline
# Missing keys automatically fall back to "offline" (rule-based reports, no external calls).
# ollama is local and needs no key (just a running `ollama serve`).
LLM_PROVIDER=offline

# Anthropic Claude
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-opus-4-8

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Google Gemini (needs `pip install google-genai`; GEMINI_API_KEY or GOOGLE_API_KEY)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Ollama — local OpenAI-compatible endpoint (uses the openai SDK, no key).
# Pull a model first, e.g. `ollama pull gemma3`, then set OLLAMA_MODEL to its tag.
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=gemma3

# Data
DEFAULT_DATA_SOURCE=yfinance
MARKET_INDEX_SYMBOL=^TWII

# Storage
DB_PATH=backtesting_copilot.sqlite
